# Required
OPENROUTER_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
GOOGLE_CREDENTIALS_PATH=.credentials.json
GOOGLE_TOKEN_PATH=token.json

# Optional
OPENROUTER_BASE_URL=https://openrouter.ai/api
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Optional task-specific overrides. Good first candidates for Gemma:
# OPENROUTER_MODEL_RELEVANCE=google/gemma-4-31b-it
# OPENROUTER_MODEL_FINANCIAL=google/gemma-4-31b-it
# Keep these on Claude unless you validate them carefully:
# OPENROUTER_MODEL_CLASSIFICATION=
# OPENROUTER_MODEL_VISION=
# OPENROUTER_MODEL_DIGEST=
# OPENROUTER_MODEL_GMAIL_ACTIONS=
# Legacy fallback only. OPENROUTER_MODEL takes precedence.
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096
GMAIL_POLL_INTERVAL=300
TELEGRAM_EMAIL_SUMMARY_NOTIFICATIONS=true
TELEGRAM_GMAIL_ACTION_NOTIFICATIONS=true
# Optional Gmail backfill cutoff for the watcher bootstrap. Defaults to today's local date on first run.
# GMAIL_START_DATE=2026-04-05
# Optional. Pins relative dates like "Monday" to a specific local timezone.
JARVIS_TIMEZONE=Europe/Berlin
JARVIS_DB_PATH=./data/jarvis_memory.db
JARVIS_CHROMA_PATH=./data/jarvis_chroma
JARVIS_MORNING_DIGEST_ENABLED=true
JARVIS_MORNING_TIME=09:00
JARVIS_DAILY_PICTURE_WINDOW_HOURS=12
JARVIS_DAILY_PICTURE_LLM_RANKING=false
JARVIS_DAILY_PLANNER_ENABLED=true
JARVIS_DAILY_PLANNER_TIME=08:30
JARVIS_DAILY_PLANNER_END_TIME=18:00
JARVIS_DAILY_PLANNER_BUFFER_MINUTES=10
# Optional. Point this at an Obsidian vault to enable collaborative notes.
# Example: /Users/you/Documents/Obsidian
OBSIDIAN_VAULT_PATH=
# Optional. Use "." to write directly at the vault root.
OBSIDIAN_ROOT_FOLDER=Marvis
# Optional. Enables GitHub issue, pull request, and commit read access.
# Format: owner/repo
JARVIS_GITHUB_REPOSITORY=
# Optional. Needed for private repositories and higher authenticated rate limits.
# JARVIS_GITHUB_TOKEN=ghp_xxx
JARVIS_GITHUB_TOKEN=
# Optional. Only set this for GitHub Enterprise Server.
# JARVIS_GITHUB_API_BASE=https://github.example.com/api/v3

# Optional Langfuse tracing for article-grade observability.
JARVIS_LANGFUSE_ENABLED=false
JARVIS_LANGFUSE_CAPTURE_CONTENT=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional local document anonymization before remote LLM processing.
# Enable this only after you have a local Ollama server running and a vetted model pulled.
JARVIS_ANONYMIZATION_ENABLED=false
JARVIS_ANONYMIZATION_FAIL_CLOSED=true
JARVIS_ANONYMIZATION_MAX_CHARS=12000
JARVIS_ANONYMIZATION_CHUNK_CHARS=2500
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Recommended starting point on a 16 GB Apple Silicon Mac mini:
OLLAMA_MODEL_ANONYMIZER=gemma3:12b
OLLAMA_TIMEOUT_SECONDS=120
